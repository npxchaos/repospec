{
  "name": "repospec",
  "version": "0.0.0",
  "private": true,
  "description": "Repospec — an open, repository-first specification for AI-assisted software engineering.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.10.0",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "typecheck": "pnpm -r typecheck",
    "schema": "node scripts/emit-schema.mjs",
    "docs:dev": "vitepress dev",
    "docs:build": "vitepress build",
    "docs:preview": "vitepress preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "changeset": "changeset",
    "release": "changeset publish"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.11",
    "@eslint/js": "^10.0.1",
    "@repospec/protocol": "workspace:*",
    "@types/node": "^26.1.1",
    "eslint": "^10.6.0",
    "prettier": "^3.9.4",
    "tsup": "^8.3.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.10",
    "zod-to-json-schema": "^3.25.2"
  }
}
