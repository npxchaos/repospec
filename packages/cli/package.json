{
  "name": "@repospec/cli",
  "version": "0.2.0",
  "description": "The Repospec CLI: one human entrypoint to the Repospec engine.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "repospec": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "@repospec/engine": "workspace:*",
    "commander": "^13.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/npxchaos/repospec.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/npxchaos/repospec#readme",
  "bugs": {
    "url": "https://github.com/npxchaos/repospec/issues"
  }
}
