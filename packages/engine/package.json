{
  "name": "@repospec/engine",
  "version": "0.3.0",
  "description": "The Repospec engine: UI-agnostic implementation of the protocol operations.",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@repospec/protocol": "workspace:*",
    "@repospec/templates": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/npxchaos/repospec.git",
    "directory": "packages/engine"
  },
  "homepage": "https://github.com/npxchaos/repospec#readme",
  "bugs": {
    "url": "https://github.com/npxchaos/repospec/issues"
  },
  "keywords": [
    "repospec",
    "agents",
    "agents-md",
    "ai-agents",
    "ai-coding",
    "coding-agents",
    "llm",
    "protocol",
    "codegen",
    "generator",
    "sync"
  ]
}
