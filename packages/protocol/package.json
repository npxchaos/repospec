{
  "name": "@repospec/protocol",
  "version": "0.2.1",
  "description": "The executable Repospec Specification: types and schemas for the .repospec/ protocol.",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/npxchaos/repospec.git",
    "directory": "packages/protocol"
  },
  "homepage": "https://github.com/npxchaos/repospec#readme",
  "bugs": {
    "url": "https://github.com/npxchaos/repospec/issues"
  },
  "keywords": [
    "repospec",
    "agents",
    "agents-md",
    "ai-agents",
    "ai-coding",
    "coding-agents",
    "llm",
    "protocol",
    "json-schema",
    "zod",
    "specification"
  ]
}
