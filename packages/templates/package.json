{
  "name": "@repospec/templates",
  "version": "0.2.0",
  "description": "Default content and adapter templates the Repospec protocol is seeded from.",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@repospec/protocol": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/npxchaos/repospec.git",
    "directory": "packages/templates"
  },
  "homepage": "https://github.com/npxchaos/repospec#readme",
  "bugs": {
    "url": "https://github.com/npxchaos/repospec/issues"
  }
}
