{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/npxchaos/repospec/main/schemas/0.1/agent.schema.json",
  "title": "Repospec agent frontmatter",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "responsibilities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "boundaries": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "model": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "name",
    "description"
  ],
  "additionalProperties": false
}
