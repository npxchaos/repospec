{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/npxchaos/repospec/main/schemas/0.1/plugin-manifest.schema.json",
  "title": "Repospec plugin manifest",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "contribute-rules",
          "contribute-agents",
          "generate-outputs",
          "read-repo",
          "network"
        ]
      },
      "default": []
    },
    "entry": {
      "type": "string",
      "default": "index.mjs"
    }
  },
  "required": [
    "id",
    "version",
    "description"
  ],
  "additionalProperties": false
}
