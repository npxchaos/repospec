{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/npxchaos/repospec/main/schemas/0.1/project.schema.json",
  "title": "Repospec project.yaml",
  "type": "object",
  "properties": {
    "repospecProtocol": {
      "type": "string",
      "minLength": 1
    },
    "project": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "application",
            "library",
            "service",
            "cli",
            "monorepo"
          ]
        },
        "repository": {
          "type": "string",
          "format": "uri"
        }
      },
      "required": [
        "name",
        "description",
        "type"
      ],
      "additionalProperties": false
    },
    "stack": {
      "type": "object",
      "properties": {
        "languages": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "runtimes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "packageManager": {
          "type": "string"
        },
        "frameworks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "testing": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "languages"
      ],
      "additionalProperties": false
    },
    "conventions": {
      "type": "object",
      "properties": {
        "formatter": {
          "type": "string"
        },
        "linter": {
          "type": "string"
        },
        "commitStyle": {
          "type": "string",
          "enum": [
            "conventional",
            "freeform"
          ]
        },
        "branching": {
          "type": "string",
          "enum": [
            "trunk",
            "github-flow",
            "gitflow"
          ]
        }
      },
      "additionalProperties": false,
      "default": {}
    },
    "documents": {
      "type": "object",
      "properties": {
        "constitution": {
          "type": "string",
          "default": "constitution.md"
        },
        "architecture": {
          "type": "string",
          "default": "architecture.md"
        },
        "workflow": {
          "type": "string",
          "default": "workflow.md"
        }
      },
      "additionalProperties": false,
      "default": {}
    },
    "agents": {
      "type": "object",
      "properties": {
        "dir": {
          "type": "string",
          "default": "agents"
        }
      },
      "additionalProperties": false,
      "default": {
        "dir": "agents"
      }
    },
    "rules": {
      "type": "object",
      "properties": {
        "dir": {
          "type": "string",
          "default": "rules"
        }
      },
      "additionalProperties": false,
      "default": {
        "dir": "rules"
      }
    },
    "adapters": {
      "type": "array",
      "items": {
        "anyOf": [
          {
            "type": "string",
            "minLength": 1
          },
          {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "options": {
                "type": "object",
                "additionalProperties": {}
              }
            },
            "required": [
              "id"
            ],
            "additionalProperties": false
          }
        ]
      },
      "default": []
    },
    "plugins": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "version": {
            "type": "string"
          },
          "options": {
            "type": "object",
            "additionalProperties": {}
          }
        },
        "required": [
          "id"
        ],
        "additionalProperties": false
      },
      "default": []
    }
  },
  "required": [
    "repospecProtocol",
    "project",
    "stack"
  ],
  "additionalProperties": false
}
