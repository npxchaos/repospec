{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/npxchaos/repospec/main/schemas/0.1/rule.schema.json",
  "title": "Repospec rule frontmatter",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "severity": {
      "type": "string",
      "enum": [
        "error",
        "warning",
        "info"
      ]
    },
    "appliesTo": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rationale": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "title",
    "severity"
  ],
  "additionalProperties": false
}
